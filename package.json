{
  "name": "chocopass",
  "version": "0.0.1",
  "description": "Modern password manager - KeePass alternative built with Electron, TypeScript, and Shadcn UI",
  "type": "module",
  "main": "dist/main.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.node.json && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist/main.js",
    "build": "tsc -p tsconfig.node.json && vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.renderer.json",
    "start": "electron dist/main.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.chocopass.app",
    "productName": "ChocoPass",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "public/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "fileAssociations": [
      {
        "ext": "cdb",
        "name": "ChocoPass Database",
        "description": "ChocoPass password database"
      }
    ]
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^41.7.1",
    "electron-builder": "^25.0.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-toggle-group": "^1.1.13",
    "clsx": "^2.1.1",
    "csv-parse": "^5.5.2",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
